# Variáveis de ambiente do backend ClickAgenda (produção)
#
# Copie este arquivo para /etc/clickagenda/backend.env no servidor e
# preencha os valores reais. NUNCA versionar esse arquivo com segredos
# preenchidos (ele fica fora do repositório, direto no servidor).
#   sudo mkdir -p /etc/clickagenda
#   sudo nano /etc/clickagenda/backend.env
#   sudo chmod 600 /etc/clickagenda/backend.env

# --- Banco de dados MySQL ---
DB_URL=jdbc:mysql://localhost:3306/clickagenda?useSSL=false&serverTimezone=UTC&createDatabaseIfNotExist=true
DB_USERNAME=clickagenda
DB_PASSWORD=SUBSTITUA_POR_UMA_SENHA_FORTE

# --- JWT (gere um valor aleatório longo, ex: openssl rand -hex 32) ---
APP_JWT_SECRET=SUBSTITUA_POR_UM_SEGREDO_ALEATORIO_LONGO

# --- URLs ---
APP_FRONTEND_URL=https://clickagenda.online
APP_CORS_ORIGINS=https://clickagenda.online,https://www.clickagenda.online

# --- Upload de arquivos ---
APP_UPLOAD_DIR=/opt/clickagenda/uploads

# --- Email (Gmail SMTP com Senha de App) ---
SPRING_MAIL_USERNAME=SEU_EMAIL@gmail.com
SPRING_MAIL_PASSWORD=SENHA_DE_APP_AQUI

# --- WhatsApp Z-API (opcional; deixe desabilitado até configurar) ---
APP_ZAPI_ENABLED=false
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# --- Asaas PIX (opcional; comece com sandbox para validar o fluxo) ---
APP_ASAAS_ENABLED=false
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
