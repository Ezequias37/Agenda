          "raw": "{\n  \"cliente\": {\n    \"id\": 1\n  },\n  \"dataHora\": \"2026-05-25T14:30:00\",\n  \"descricao\": \"Consulta de rotina\",\n  \"status\": \"AGENDADO\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/agendamentos",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "agendamentos"
          ]
        },
        "description": "Cria um novo agendamento. ⚠️ DISPARA E-MAIL DE CONFIRMAÇÃO para o cliente!"
