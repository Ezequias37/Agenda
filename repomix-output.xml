  width: 100%;
  padding: 0.75rem;
  border: 2px solid var(--border);
  border-radius: 8px;
  font-size: 1rem; /* Evita zoom automÃ¡tico no iOS */
  font-family: inherit;
  transition: all 0.3s ease;
  min-height: 44px;
}

input:focus, select:focus, textarea:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(212, 165, 116, 0.15);
}

textarea {
  resize: vertical;
  min-height: 100px;
}

/* MODAL */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 2000;
  padding: 1rem;
}

@media (min-width: 640px) {
  .modal-overlay {
    align-items: center;
  }
}

.modal {
  background: var(--white);
  border-radius: 16px 16px 16px 16px;
  width: 100%;
  max-width: 600px;
  max-height: 92vh;
  overflow-y: auto;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
}

@media (min-width: 640px) {
  .modal {
    border-radius: 12px;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.25rem 1.5rem;
  border-bottom: 2px solid var(--border);
  background: linear-gradient(135deg, var(--primary-dark), var(--primary));
  color: var(--white);
  border-radius: 16px 16px 0 0;
  position: sticky;
  top: 0;
  z-index: 1;
}

.modal-header h2 {
  margin: 0;
  font-size: 1.2rem;
}

.modal-close-btn {
  background: none;
  border: none;
  color: var(--white);
  font-size: 1.5rem;
  cursor: pointer;
  padding: 0.25rem;
  min-width: 44px;
  min-height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  padding: 1.5rem;
}

/* LISTS */
.item-list {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1rem;
}

.item-card {
  background: var(--white);
  border-radius: 12px;
  padding: 1.25rem;
  box-shadow: 0 4px 15px rgba(139, 111, 71, 0.1);
  border-top: 4px solid var(--primary);
  transition: all 0.3s ease;
}

.item-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 25px rgba(139, 111, 71, 0.2);
}

.item-card h3 {
  color: var(--primary-dark);
  margin-bottom: 0.4rem;
  font-size: 1rem;
}

.item-card p {
  color: #666;
  font-size: 0.875rem;
  margin-bottom: 0.4rem;
}

.item-card-actions {
  display: flex;
  gap: 0.5rem;
  margin-top: 0.75rem;
  flex-wrap: wrap;
}

/* LOADING */
.spinner {
  display: inline-block;
  width: 30px;
  height: 30px;
  border: 4px solid var(--border);
  border-top: 4px solid var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 3rem;
}

/* ERROR MESSAGE */
.error-box {
  background: #FADBD8;
  border-left: 5px solid var(--danger);
  padding: 1.25rem;
  border-radius: 6px;
  margin: 1rem 0;
}

.error-box strong {
